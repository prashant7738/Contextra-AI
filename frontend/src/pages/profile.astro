---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Profile – Contextra AI</title>
  </head>
  <body>
    <main class="app-shell" id="app-root">
      <div class="ambient ambient-one"></div>
      <div class="ambient ambient-two"></div>

      <!-- Topbar -->
      <header class="topbar panel">
        <div class="topbar-brand">
          <a href="/dashboard" class="back-link" aria-label="Back to dashboard">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </a>
          <p class="eyebrow">Contextra AI</p>
          <h1>Profile</h1>
        </div>
        <div class="topbar-actions">
          <a href="/dashboard" class="button button-ghost">← Dashboard</a>
        </div>
      </header>

      <!-- Profile content -->
      <section class="profile-page-body">
        <div class="profile-card panel">
          <div class="profile-card-head">
            <div id="profile-big-avatar" class="profile-big-avatar">U</div>
            <div>
              <p class="eyebrow">Your account</p>
              <h2 id="profile-full-name" class="profile-full-name">Loading…</h2>
              <p id="profile-email" class="profile-email muted">—</p>
            </div>
          </div>

          <hr class="profile-divider" />

          <div class="profile-fields">
            <div class="profile-field">
              <span class="profile-field-label">Name</span>
              <span id="pf-name" class="profile-field-value">—</span>
            </div>
            <div class="profile-field">
              <span class="profile-field-label">Email</span>
              <span id="pf-email" class="profile-field-value">—</span>
            </div>
            <div class="profile-field">
              <span class="profile-field-label">User ID</span>
              <span id="pf-id" class="profile-field-value muted">—</span>
            </div>
          </div>

          <div class="profile-actions">
            <button id="profile-logout-btn" class="button profile-logout-button" type="button">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
              Logout
            </button>
          </div>
        </div>
      </section>
    </main>

    <style>
      .back-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.7);
        color: var(--muted);
        text-decoration: none;
        transition: background 0.18s, color 0.18s;
      }

      .back-link:hover {
        background: rgba(31, 61, 54, 0.08);
        color: var(--accent);
      }

      .topbar-brand {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .profile-page-body {
        display: flex;
        justify-content: center;
        padding-top: 16px;
      }

      .profile-card {
        width: 100%;
        max-width: 520px;
        padding: 36px;
        display: flex;
        flex-direction: column;
        gap: 28px;
      }

      .profile-card-head {
        display: flex;
        align-items: center;
        gap: 20px;
      }

      .profile-big-avatar {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 68px;
        height: 68px;
        border-radius: 999px;
        font-size: 1.6rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        background: var(--accent);
        color: #f8f5ef;
        flex-shrink: 0;
      }

      .profile-full-name {
        margin: 0 0 4px;
        font-family: "Fraunces", serif;
        font-size: 1.5rem;
        letter-spacing: -0.02em;
      }

      .profile-email {
        margin: 0;
        font-size: 0.9rem;
      }

      .profile-divider {
        border: none;
        border-top: 1px solid var(--line);
        margin: 0;
      }

      .profile-fields {
        display: grid;
        gap: 16px;
      }

      .profile-field {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 14px 16px;
        border: 1px solid var(--line);
        border-radius: var(--radius-md);
        background: rgba(255, 255, 255, 0.55);
      }

      .profile-field-label {
        font-size: 0.82rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
        font-weight: 600;
      }

      .profile-field-value {
        font-weight: 500;
        font-size: 0.95rem;
        text-align: right;
      }

      .profile-actions {
        display: flex;
        justify-content: flex-end;
      }

      .profile-logout-button {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(140, 47, 47, 0.08);
        border-color: rgba(140, 47, 47, 0.2);
        color: var(--danger);
        font-weight: 600;
      }

      .profile-logout-button:hover {
        background: rgba(140, 47, 47, 0.14);
      }
    </style>

    <script>
      // @ts-nocheck
      (function () {
        try {
          if (!localStorage.getItem('access_token')) {
            window.location.href = '/login';
            return;
          }
        } catch {
          window.location.href = '/login';
          return;
        }

        let user = null;
        try {
          const userJson = localStorage.getItem('current_user');
          if (userJson) user = JSON.parse(userJson);
        } catch {}

        if (!user) {
          window.location.href = '/login';
          return;
        }

        // Populate fields
        const fullName = user.name || 'Unknown';
        const email = user.email || '—';
        const userId = user.id || '—';

        const initials = fullName.split(' ').map(p => p[0]).join('').slice(0, 2).toUpperCase() || 'U';

        const bigAvatar = document.getElementById('profile-big-avatar');
        const fullNameEl = document.getElementById('profile-full-name');
        const profileEmailEl = document.getElementById('profile-email');
        const pfName = document.getElementById('pf-name');
        const pfEmail = document.getElementById('pf-email');
        const pfId = document.getElementById('pf-id');
        const logoutBtn = document.getElementById('profile-logout-btn');

        if (bigAvatar) bigAvatar.textContent = initials;
        if (fullNameEl) fullNameEl.textContent = fullName;
        if (profileEmailEl) profileEmailEl.textContent = email;
        if (pfName) pfName.textContent = fullName;
        if (pfEmail) pfEmail.textContent = email;
        if (pfId) pfId.textContent = String(userId);

        logoutBtn?.addEventListener('click', () => {
          localStorage.removeItem('access_token');
          localStorage.removeItem('current_user');
          window.location.href = '/login';
        });
      })();
    </script>
  </body>
</html>
