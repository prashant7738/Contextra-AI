---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Chat messages – Admin" requireAuth>
  <main id="main" style="max-width:900px;margin:48px auto;padding:24px;">
    <p><a href="/admin">← Back to admin</a></p>
    <h2 id="heading">Messages</h2>
    <div id="loading">Loading messages…</div>
    <ul id="messages" style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:12px"></ul>
  </main>

  <script>
    import { apiClient } from '../../utils/api';

    interface AdminMessage {
      user_id: number;
      user_message: string;
      bot_response: string;
      created_at: string;
    }

    const params = new URLSearchParams(window.location.search);
    const chatId = params.get('id');
    const msgsEl = document.getElementById('messages') as HTMLUListElement | null;
    const loadingEl = document.getElementById('loading') as HTMLElement | null;
    const headingEl = document.getElementById('heading') as HTMLHeadingElement | null;

    if (!chatId) {
      if (loadingEl) loadingEl.style.display = 'none';
      if (msgsEl) {
        msgsEl.innerHTML =
          '<li style="padding:12px;background:#fee;color:#600">Missing chat id in URL (?id=…)</li>';
      }
    } else {
      if (headingEl) headingEl.textContent = `Messages for chat #${chatId}`;
      void load();
    }

    async function load() {
      if (!msgsEl || !loadingEl) return;
      loadingEl.style.display = 'block';
      const res = await apiClient.get<AdminMessage[]>(`/admin/chats/${chatId}/messages`);
      loadingEl.style.display = 'none';
      if (res.error) {
        msgsEl.innerHTML = `<li style="padding:12px;background:#fee;color:#600">${res.error}</li>`;
        return;
      }
      const msgs = res.data ?? [];
      if (!msgs.length) {
        msgsEl.innerHTML =
          '<li style="padding:12px;background:#f4f6f9;border-radius:8px">No messages</li>';
        return;
      }
      msgsEl.innerHTML = msgs
        .map(
          (m) => `
        <li style="padding:12px;background:#fff;border-radius:8px;border:1px solid #eef">
          <div style="font-weight:600">User: ${m.user_id}</div>
          <div style="color:#333;margin-top:6px">${m.user_message}</div>
          <div style="color:#0b66ff;margin-top:8px">Bot: ${m.bot_response}</div>
          <div style="font-size:12px;color:#7b8997;margin-top:6px">${new Date(m.created_at).toLocaleString()}</div>
        </li>`
        )
        .join('');
    }
  </script>
</BaseLayout>
