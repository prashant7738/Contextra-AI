---
const { id } = Astro.params;
import Layout from '../../../../components/AuthWrapper.jsx';
---
<Layout>
  <main style="max-width:900px;margin:48px auto;padding:24px;">
    <h2>Messages for chat #{id}</h2>
    <div id="loading">Loading messages…</div>
    <ul id="messages" style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:12px"></ul>
  </main>

  <script type="module">
    import { apiClient } from '/src/utils/api';
    const msgsEl = document.getElementById('messages');
    const loadingEl = document.getElementById('loading');
    async function load(){
      loadingEl.style.display='block';
      const res = await apiClient.get(`/admin/chats/${id}/messages`);
      loadingEl.style.display='none';
      if(res.error){
        msgsEl.innerHTML = `<li style="padding:12px;background:#fee;color:#600">${res.error}</li>`;
        return;
      }
      const msgs = res.data || [];
      if(!msgs.length){
        msgsEl.innerHTML = '<li style="padding:12px;background:#f4f6f9;border-radius:8px">No messages</li>';
        return;
      }
      msgsEl.innerHTML = msgs.map(m => `
        <li style="padding:12px;background:#fff;border-radius:8px;border:1px solid #eef">
          <div style="font-weight:600">User: ${m.user_id}</div>
          <div style="color:#333;margin-top:6px">${m.user_message}</div>
          <div style="color:#0b66ff;margin-top:8px">Bot: ${m.bot_response}</div>
          <div style="font-size:12px;color:#7b8997;margin-top:6px">${new Date(m.created_at).toLocaleString()}</div>
        </li>
      `).join('');
    }
    load();
  </script>
</Layout>
