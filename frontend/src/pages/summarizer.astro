---
import DetailedSummarizer from '../components/DetailedSummarizer.tsx';
import { ErrorBoundary } from '../components/ErrorBoundary.tsx';
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Detailed Summarizer – Contextra AI"
  description="Extract and refine summaries from your chat history by topic."
  requireAuth
  bodyClass="summarizer-body"
>
  <main id="main">
    <ErrorBoundary client:load>
      <DetailedSummarizer client:load />
    </ErrorBoundary>
  </main>

  <style is:global>
    body.summarizer-body {
      background: linear-gradient(135deg, #0f0f12 0%, #1a1a24 100%);
      color: #f5f5f7;
      font-family: 'IBM Plex Sans', system-ui, sans-serif;
    }
  </style>
</BaseLayout>
