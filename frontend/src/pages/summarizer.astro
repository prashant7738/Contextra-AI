---
// Astro page component for DetailedSummarizer
import DetailedSummarizer from '../components/DetailedSummarizer.jsx';
import '../styles/global.css';

const title = 'Detailed Summarizer | Contextra AI';
const description = 'Extract and refine summaries from your chat history by topic.';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title}</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@400;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <style>
      html {
        background: #0f0f12;
        font-family: 'DM Sans', system-ui, sans-serif;
      }

      body {
        margin: 0;
        padding: 0;
        background: linear-gradient(135deg, #0f0f12 0%, #1a1a24 100%);
        color: #f5f5f7;
      }

      * {
        box-sizing: border-box;
      }
    </style>
  </head>
  <body>
    <DetailedSummarizer client:load />
  </body>
</html>
