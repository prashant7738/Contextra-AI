---
import Layout from '../components/AuthWrapper.jsx';
---
<Layout>
  <main class="admin-root">
    <h1 class="title">Admin Panel</h1>
    <p class="subtitle">User list and chat inspection (admin only)</p>

    <section id="content">
      <div id="loading">Loading users…</div>
      <ul id="users" class="users-grid"></ul>
    </section>
  </main>

  <style>
    .admin-root{max-width:1100px;margin:48px auto;padding:24px;background:linear-gradient(180deg,rgba(255,255,255,0.02),rgba(0,0,0,0.02));border-radius:12px;box-shadow:0 10px 30px rgba(8,12,20,0.25);}
    .title{font-size:28px;margin:0 0 4px;color:#0b1220}
    .subtitle{margin:0 0 18px;color:#41515f}
    .users-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px;list-style:none;padding:0;margin:0}
    .user-card{background:linear-gradient(135deg,#ffffff, #f4f7fb);padding:14px;border-radius:10px;border:1px solid rgba(10,14,20,0.04);}
    .user-card h3{margin:0 0 6px;font-size:16px}
    .user-card p{margin:0;color:#5b6b7b;font-size:13px}
    .small{font-size:12px;color:#7b8997;margin-top:8px}
    a.chats-link{display:inline-block;margin-top:10px;color:#0b66ff;text-decoration:none}
  </style>

  <script type="module">
    import { apiClient } from '../utils/api';
    const usersEl = document.getElementById('users');
    const loadingEl = document.getElementById('loading');

    async function loadUsers(){
      loadingEl.style.display='block';
      const res = await apiClient.get('/admin/users');
      loadingEl.style.display='none';
      if(res.error){
        usersEl.innerHTML = `<li class="user-card">Error: ${res.error}</li>`;
        return;
      }
      const users = res.data || [];
      if(!users.length){
        usersEl.innerHTML = '<li class="user-card">No users found</li>';
        return;
      }
      usersEl.innerHTML = users.map(u => `
        <li class="user-card">
          <h3>${u.name}</h3>
          <p>${u.email}</p>
          <div class="small">ID: ${u.id}</div>
          <a class="chats-link" href="/admin/user/${u.id}/chats">View chats</a>
        </li>
      `).join('');
    }
    loadUsers();
  </script>
</Layout>
