---
import BaseLayout from '../layouts/BaseLayout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
---
<BaseLayout title="Dashboard – Contextra AI" description="Contextra AI Dashboard" requireAuth>
    <main class="app-shell" id="main">
      <div class="ambient ambient-one" aria-hidden="true"></div>
      <div class="ambient ambient-two" aria-hidden="true"></div>

      <header class="topbar panel" id="topbar">
        <div class="topbar-brand">
          <button id="mobile-hamburger" class="mobile-hamburger" aria-label="Open menu" aria-expanded="false">
            <span class="mh-bar" aria-hidden="true"></span>
            <span class="mh-bar" aria-hidden="true"></span>
            <span class="mh-bar" aria-hidden="true"></span>
          </button>
          <p class="eyebrow">Contextra AI</p>
          <h1>Study cockpit</h1>
        </div>

        <nav class="topbar-nav" id="topbar-nav" aria-label="Main navigation">
          <button id="nav-chat-btn" class="nav-tab nav-tab-active" type="button">Chat</button>
          <button id="summarizer-btn" class="nav-tab" type="button" style="display:none">Summarizer</button>
          <button id="flashcard-btn" class="nav-tab" type="button" style="display:none">Flashcards</button>
        </nav>

        <div class="topbar-actions">
          <ThemeToggle class="theme-toggle-navbar" />
          <div id="profile-pill" class="profile-pill" aria-live="polite">
            <span id="profile-avatar" class="profile-avatar">U</span>
            <span id="profile-name">User</span>
            <!-- Three-line menu toggle (desktop) -->
            <button id="profile-menu-toggle" class="profile-menu-toggle" type="button" aria-expanded="false" aria-label="Open profile menu">
              <span class="pmenu-bar" aria-hidden="true"></span>
              <span class="pmenu-bar" aria-hidden="true"></span>
              <span class="pmenu-bar" aria-hidden="true"></span>
            </button>
            <!-- Profile dropdown -->
            <div id="profile-dropdown" class="profile-dropdown" hidden>
              <a href="/profile" class="profile-dropdown-item">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M3 21a9 9 0 0 1 18 0"/></svg>
                Profile
              </a>
              <button id="logout-btn" class="profile-dropdown-item profile-dropdown-danger" type="button">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                Logout
              </button>
            </div>
            <!-- Mobile caret (shown on mobile only) -->
            <button id="mobile-caret" class="mobile-caret" type="button" aria-expanded="false" aria-label="Open profile menu"><span aria-hidden="true">▾</span></button>
            <div id="mobile-profile-menu" class="mobile-profile-menu" hidden>
              <button id="mobile-summarizer" class="button button-ghost" type="button">Summarizer</button>
              <button id="mobile-flashcard" class="button button-ghost" type="button">Flashcards</button>
              <button id="mobile-logout" class="button button-ghost" type="button">Logout</button>
            </div>
          </div>
        </div>
      </header>

      <section class="frame frame-rails" id="frame-rails">
        <aside class="sidebar panel left-rail" id="left-rail">
          <div class="brand-block">
            <p class="eyebrow">Workspace</p>
            <button id="mobile-chat-toggle" class="mobile-chat-toggle" type="button" aria-label="Open chats" aria-expanded="false">
              <span class="bar" aria-hidden="true"></span>
              <span class="bar" aria-hidden="true"></span>
              <span class="bar" aria-hidden="true"></span>
            </button>
            <h2>Quiet chat workspace</h2>
          </div>

          <div class="stack">
            <div class="section-head">
              <h2>Chats</h2>
              <button id="refresh-chats" class="button button-ghost" type="button">Refresh</button>
            </div>
            <form id="chat-form" class="row-form">
              <label for="chat-name" class="visually-hidden">New chat name</label>
              <input id="chat-name" type="text" placeholder="New study thread" autocomplete="off" />
              <button class="button button-primary" type="submit">New</button>
            </form>
            <div id="chat-list" class="chat-list"></div>
          </div>
        </aside>

        <div class="resize-handle" id="left-resize" role="separator" aria-orientation="vertical" title="Drag to resize left sidebar">
          <button id="left-toggle" class="rail-toggle" aria-label="Toggle left sidebar">‹</button>
        </div>

        <section class="workspace panel">
          <header class="workspace-head">
            <div>
              <p class="eyebrow">Live backend connection</p>
              <h2 id="chat-title">Select a chat</h2>
            </div>
            <div class="pills">
              <span id="identity-pill" class="pill">No user selected</span>
              <span id="connection-pill" class="pill pill-soft">Waiting</span>
            </div>
          </header>

          <div id="message-stream" class="message-stream">
            <div class="empty-state">
              <h3>Select a chat</h3>
              <p>Choose a chat from the left sidebar or create a new one to start asking questions about your notes.</p>
            </div>
          </div>

          <!-- Summary panel (replaces chat view when activated) -->
          <div id="summary-panel-container" class="panel" hidden>
            <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;padding:12px 18px;border-bottom:1px solid var(--line)">
              <div>
                <p class="eyebrow">Insight Layer</p>
                <h3>80-20 Summarizer</h3>
              </div>
              <div style="display:flex;gap:8px;align-items:center">
                <span id="summary-chat-pill" class="pill">No chat selected</span>
                <button id="summary-close" class="button button-ghost" type="button">Back</button>
              </div>
            </div>
            <div style="padding:18px">
              <form id="summary-form" class="summary-controls">
                <label class="field">
                  <span>Topic focus</span>
                  <input id="summary-topic" type="text" placeholder="all, chapter 3, architecture decisions..." autocomplete="off" />
                </label>
                <label class="field">
                  <span>Context chunks</span>
                  <select id="summary-results">
                    <option value="3">3 chunks</option>
                    <option value="5" selected>5 chunks</option>
                    <option value="10">10 chunks</option>
                    <option value="15">15 chunks</option>
                  </select>
                </label>
                <div class="summary-actions">
                  <button id="summary-generate" class="button button-primary" type="submit">Generate</button>
                  <button id="summary-clear" class="button button-ghost" type="button">Clear</button>
                </div>
              </form>
              <div id="summary-output" class="summary-output" style="margin-top:16px">
                <p class="empty">Generate a focused summary for the selected chat.</p>
              </div>
            </div>
          </div>

          <!-- Flashcard panel (replaces chat view when activated) -->
          <div id="flashcard-panel-container" class="panel" hidden>
            <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;padding:12px 18px;border-bottom:1px solid var(--line)">
              <div>
                <p class="eyebrow">Memory Layer</p>
                <h3>Flashcards</h3>
                <p class="flashcard-copy">Generate clean, topic-grouped recall cards from the selected chat.</p>
              </div>
              <div style="display:flex;gap:8px;align-items:center">
                <span id="flashcard-chat-pill" class="pill">No chat selected</span>
                <button id="flashcard-close" class="button button-ghost" type="button">Back</button>
              </div>
            </div>
            <div style="padding:18px">
              <div class="flashcard-head" style="display:flex;justify-content:space-between;align-items:center">
                <div style="min-width:0">
                  <div class="flashcard-stats" style="display:flex;gap:14px;margin-bottom:12px">
                    <div class="flashcard-stat">
                      <strong id="flashcard-topic-count">0</strong>
                      <span>Topics</span>
                    </div>
                    <div class="flashcard-stat">
                      <strong id="flashcard-count">0</strong>
                      <span>Cards</span>
                    </div>
                    <div class="flashcard-stat">
                      <strong id="flashcard-chunk-count">5</strong>
                      <span>Chunks</span>
                    </div>
                  </div>
                </div>
                <div class="flashcard-actions">
                  <button id="flashcard-generate" class="button button-primary" type="button">Generate</button>
                </div>
              </div>

              <div class="summary-controls" style="margin-top:12px">
                <label class="field">
                  <span>Context chunks</span>
                  <select id="flashcard-results">
                    <option value="3">3 chunks</option>
                    <option value="5" selected>5 chunks</option>
                    <option value="10">10 chunks</option>
                    <option value="15">15 chunks</option>
                  </select>
                </label>
                <div class="summary-actions" style="margin-top:12px">
                  <button id="flashcard-clear" class="button button-ghost" type="button">Clear</button>
                </div>
              </div>

              <p id="flashcard-status" class="status-line flashcard-status" style="margin-top:12px"></p>
              <div id="flashcard-output" class="flashcard-output" style="margin-top:12px">
                <p class="empty">Generate flashcards to see learning cards here.</p>
              </div>
            </div>
          </div>

          <div id="composer" class="composer" hidden>
            <div id="composer-upload" class="composer-upload" hidden>
              <label class="dropzone" id="dropzone-label" for="file-input">
                <strong>Drop PDF here or click to choose a file</strong>
                <span>Upload one PDF per chat to index references before asking questions.</span>
              </label>
              <div class="upload-row">
                <input id="file-input" type="file" accept=".pdf,application/pdf" />
                <button id="upload-btn" class="button button-primary" type="button">Upload PDF</button>
              </div>
            </div>
            <div class="composer-bar">
              <label for="query-input" class="visually-hidden">Ask a question about your notes</label>
              <input id="query-input" type="text" placeholder="Ask a question about your notes..." autocomplete="off" />
              <button id="send-btn" class="button button-primary" type="button">Send</button>
            </div>
            <div id="chat-doc-list" class="chat-doc-list" style="padding:10px 18px;border-top:1px solid var(--line);background:transparent;display:none">
              <strong>Uploaded files</strong>
              <ul id="chat-doc-list-items" style="margin:8px 0 0;padding-left:18px"></ul>
            </div>
            <p id="status-line" class="status-line"></p>
          </div>
        </section>

        <!-- Right rail removed: panels moved into workspace when activated -->
      </section>
    </main>

    <!-- Action modal (rename / delete) -->
    <div id="action-modal" class="modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="modal-title" hidden>
      <div class="modal" role="document">
        <div class="modal-header">
          <h3 id="modal-title" class="modal-title">Confirm</h3>
          <button id="modal-close" class="button" type="button" aria-label="Close dialog"><span aria-hidden="true">✕</span></button>
        </div>
        <div class="modal-body">
          <p id="modal-message">Are you sure?</p>
          <input id="modal-input" class="input" type="text" style="display:none;margin-top:8px" />
          <p id="modal-error" class="modal-error" hidden></p>
        </div>
        <div class="modal-actions">
          <button id="modal-cancel" class="btn-secondary" type="button">Cancel</button>
          <button id="modal-confirm" class="btn-danger" type="button">Confirm</button>
        </div>
      </div>
    </div>

    <!-- Mobile full-screen overlay for menu (mobile only) -->
    <div id="mobile-overlay" class="mobile-overlay" role="dialog" aria-modal="true" aria-label="Mobile menu" hidden>
      <div class="mobile-overlay-inner">
        <div class="mobile-overlay-head">
          <button id="mobile-hamburger-close" class="mobile-hamburger-close" aria-label="Close menu">✕</button>
        </div>
        <div class="mobile-overlay-actions">
          <button id="overlay-summarizer" class="button button-ghost" type="button">Summarizer</button>
          <button id="overlay-flashcard" class="button button-ghost" type="button">Flashcards</button>
          <button id="overlay-logout" class="button button-ghost" type="button">Logout</button>
        </div>
        <div class="mobile-overlay-chats">
          <div class="section-head"><h2>Chats</h2></div>
          <div id="overlay-chat-list" class="chat-list"></div>
        </div>
      </div>
    </div>

    <script>
      import '../scripts/dashboard.ts';
    </script>
</BaseLayout>