---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Contextra AI Dashboard" />
    <title>Dashboard - Contextra AI</title>
  </head>
  <body>
    <main class="app-shell" id="app-root">
      <div class="ambient ambient-one"></div>
      <div class="ambient ambient-two"></div>

      <section class="frame">
        <aside class="sidebar panel">
          <div class="brand-block">
            <p class="eyebrow">Contextra AI</p>
            <h1>Quiet chat workspace</h1>
            <p class="lede">Create a user, open a chat, upload PDFs, and talk to the backend in one place.</p>
          </div>

          <div class="auth-section" style="margin-bottom: 20px;">
            <div id="user-profile"></div>
            <button id="logout-btn" class="button button-ghost" type="button">Logout</button>
          </div>

          <form id="user-form" class="stack">
            <label class="field">
              <span>New user</span>
              <input id="user-name" name="user-name" type="text" placeholder="Ava Stone" autocomplete="off" />
            </label>
            <button class="button button-primary" type="submit">Create user</button>
          </form>

          <div class="stack">
            <div class="section-head">
              <h2>Users</h2>
              <button id="refresh-users" class="button button-ghost" type="button">Refresh</button>
            </div>
            <div id="user-list" class="choice-list"></div>
          </div>

          <details class="chat-disclosure">
            <summary class="disclosure-summary section-head">
              <h2>Chats</h2>
              <span class="disclosure-hint">Open chat list</span>
            </summary>
            <div class="disclosure-body stack">
              <button id="refresh-chats" class="button button-ghost" type="button">Refresh</button>
              <form id="chat-form" class="row-form">
                <input id="chat-name" type="text" placeholder="New study thread" autocomplete="off" />
                <button class="button button-primary" type="submit">New</button>
              </form>
              <div id="chat-list" class="chat-list"></div>
            </div>
          </details>

        </aside>

        <section class="workspace panel">
          <header class="workspace-head">
            <div>
              <p class="eyebrow">Live backend connection</p>
              <h2 id="chat-title">Select a user and chat</h2>
            </div>
            <div class="pills">
              <span id="identity-pill" class="pill">No user selected</span>
              <span id="connection-pill" class="pill pill-soft">Waiting</span>
            </div>
          </header>

          <details class="summary-disclosure" aria-live="polite">
            <summary class="disclosure-summary summary-head">
              <div>
                <p class="eyebrow">Insight Layer</p>
                <h3>Detailed summary</h3>
              </div>
              <span id="summary-chat-pill" class="pill">No chat selected</span>
            </summary>

            <div class="disclosure-body summary-panel">
              <form id="summary-form" class="summary-controls">
                <label class="field">
                  <span>Topic focus</span>
                  <input id="summary-topic" type="text" placeholder="all, chapter 3, architecture decisions..." autocomplete="off" />
                </label>
                <label class="field">
                  <span>Context chunks</span>
                  <select id="summary-results">
                    <option value="3">3 chunks</option>
                    <option value="5" selected>5 chunks</option>
                    <option value="10">10 chunks</option>
                    <option value="15">15 chunks</option>
                  </select>
                </label>
                <div class="summary-actions">
                  <button id="summary-generate" class="button button-primary" type="submit">Generate</button>
                  <button id="summary-clear" class="button button-ghost" type="button">Clear</button>
                </div>
              </form>
            </div>
          </details>
        </section>
      </section>
    </main>

    <script>
      // Check if user is authenticated
      function isAuthenticated() {
        try {
          const token = localStorage.getItem('access_token');
          return !!token;
        } catch {
          return false;
        }
      }

      function getCurrentUser() {
        try {
          const userJson = localStorage.getItem('current_user');
          return userJson ? JSON.parse(userJson) : null;
        } catch {
          return null;
        }
      }

      // Redirect if not authenticated
      if (!isAuthenticated()) {
        window.location.href = '/login';
      } else {
        // Display current user
        const user = getCurrentUser();
        if (user) {
          const profileDiv = document.getElementById('user-profile');
          if (profileDiv) {
            profileDiv.innerHTML = `
              <p style="margin: 0 0 10px 0; font-size: 14px; color: #666;">Logged in as:</p>
              <p style="margin: 0; font-weight: 600; color: #333;">${user.name}</p>
              <p style="margin: 0; font-size: 12px; color: #999;">${user.email}</p>
            `;
          }
        }

        // Handle logout
        const logoutBtn = document.getElementById('logout-btn');
        if (logoutBtn) {
          logoutBtn.addEventListener('click', () => {
            // Clear tokens
            localStorage.removeItem('access_token');
            localStorage.removeItem('refresh_token');
            localStorage.removeItem('current_user');
            window.location.href = '/login';
          });
        }
      }
    </script>
  </body>
</html>
