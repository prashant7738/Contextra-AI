---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contextra AI" description="Contextra AI — context-aware AI workspace.">
  <main id="main" class="splash">
    <p>Loading…</p>
  </main>
  <style>
    .splash {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
    }
  </style>
  <script is:inline>
    (function () {
      try {
        var token = localStorage.getItem('access_token');
        window.location.replace(token ? '/dashboard' : '/login');
      } catch (_) {
        window.location.replace('/login');
      }
    })();
  </script>
</BaseLayout>
